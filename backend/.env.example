# QC Inspector backend configuration template.
# Copy to .env and fill in machine-specific values. NEVER commit a real .env.
# Moving to a different machine (GPU box, colleague's laptop) = edit THIS only.

# ---- App ----
APP_NAME=QC Inspector OCR Service
HOST=0.0.0.0
PORT=8002
# Comma-separated list of allowed CORS origins (the React dev server, etc.)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8002
LOG_LEVEL=INFO
DATA_ROOT=data

# ---- Active providers (swap model/provider WITHOUT touching source) ----
ACTIVE_LAYOUT_PROVIDER=paddlex_doclayout      # local on every machine
ACTIVE_OCR_PROVIDER=paddleocr_vl              # paddleocr_vl (remote) | paddleocr_vl_local
ACTIVE_LLM_PROVIDER=openai_compatible         # any OpenAI-compatible endpoint
ACTIVE_SPEC_STORE=sqlite                      # sqlite | postgres
ACTIVE_SPEC_LOOKUP_STRATEGY=sap_then_local_store

# ---- Layout detection (PP-DocLayoutV3, LOCAL on CPU here) ----
LAYOUT_MODEL_NAME=PP-DocLayoutV3
LAYOUT_MODEL_HF_REPO=PaddlePaddle/PP-DocLayoutV3_safetensors
LAYOUT_MODEL_DIR=models/PP-DocLayoutV3_safetensors
LAYOUT_DEVICE=cpu                             # cpu here; cuda on the GPU box
LAYOUT_SCORE_THRESHOLD=0.10
HF_CACHE_DIR=models/.hf_cache

# ---- OCR (PaddleOCR-VL) ----
# Default: REMOTE OpenAI-compatible endpoint (ACTIVE_OCR_PROVIDER=paddleocr_vl).
OCR_SERVICE_URL=http://REPLACE_ME_OCR_HOST:8102
OCR_RECOGNIZE_PATH=/v1/chat/completions
OCR_MODEL_NAME=paddleocr-vl-16
OCR_TIMEOUT_SECONDS=1800
OCR_MAX_CONCURRENCY=4
OCR_AUTH_SCHEME=bearer                        # bearer | basic
OCR_BEARER_KEY=replace-me-ocr-token
OCR_BASIC_USER=
OCR_BASIC_PASSWORD=
# OPTIONAL local OCR (ACTIVE_OCR_PROVIDER=paddleocr_vl_local) — needs disk/RAM +
# requirements-ml.txt; pull weights with: python scripts/download_models.py --ocr
OCR_LOCAL_MODEL_HF_REPO=PaddlePaddle/PaddleOCR-VL-1.6
OCR_LOCAL_MODEL_DIR=models/PaddleOCR-VL-1.6
OCR_LOCAL_DEVICE=cpu                          # cpu here; cuda on the GPU box
OCR_LOCAL_DTYPE=float32
OCR_LOCAL_MAX_NEW_TOKENS=2048

# ---- Deduplication (IoU) ----
DEDUP_IOU_THRESHOLD=0.5
DEDUP_CONTAINMENT_THRESHOLD=0.8

# ---- LLM (OpenAI-compatible; provider = openai_compatible) ----
# The same provider talks to ANY OpenAI-compatible endpoint — only .env changes:
#   vLLM/Qwen : LLM_BASE_URL=http://GPU_HOST:8000/v1            LLM_MODEL=qwen3
#   Ollama    : LLM_BASE_URL=http://localhost:11434/v1          LLM_MODEL=qwen2.5:7b   (LLM_API_KEY=ollama)
#   Gemini    : LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#               LLM_MODEL=gemini-2.0-flash                       LLM_API_KEY=<google api key>
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=ollama
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8192
SEGMENTATION_TIMEOUT_SECONDS=600
COMPARISON_TIMEOUT_SECONDS=600
AGGREGATION_TIMEOUT_SECONDS=300

# ---- SAP spec service (Basic auth) ----
SAP_SPEC_ENDPOINT=https://REPLACE_ME_SAP_HOST/erp-mm/part-spec
SAP_SPEC_READ_PATH=/read-text
SAP_SPEC_TIMEOUT_SECONDS=150
SAP_API_USER=replace-me-sap-user
SAP_API_PASSWORD=replace-me-sap-password
SPEC_SOURCE=local                             # sap | local

# ---- Spec indexing pipeline (2B) ----
# Local mock folder now; becomes a real UNC path later with no code change.
SPEC_NETWORK_ROOT=data/spec_store/mock_specs
SPEC_STORE_BACKEND=sqlite
SPEC_STORE_DB_PATH=data/spec_store/spec_store.db
SPEC_OUTPUT_DIR=data/spec_store/outputs
SPEC_INDEX_DIR=data/specs_index
SPEC_HASH_ALGORITHM=sha256
SPEC_FUZZY_MATCH_THRESHOLD=0.85
SPEC_REINDEX_IF_HASH_CHANGED=true
SPEC_REINDEX_IF_REVISION_CHANGED=true
SPEC_INDEX_MODE=incremental
SPEC_INDEX_SCHEDULE=
SPEC_OCR_MAX_PAGES=1

# ---- Relational store (runs / findings / overrides) ----
DATABASE_URL=sqlite:///data/qc_inspector.db
DB_ECHO=false

# ---- PDF rendering ----
PDF_RENDER_DPI=150
UPLOAD_OCR_MAX_PAGES=1

# ---- TLS / mTLS (paths are config-driven; never commit private keys) ----
TLS_CA_CERT_PATH=
TLS_CLIENT_CERT_PATH=
TLS_CLIENT_KEY_PATH=
TLS_VERIFY=true
