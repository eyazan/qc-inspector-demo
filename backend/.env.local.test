# ==========================================================================
# QC Inspector — LOCAL end-to-end test template (NO mocks; real services).
# Copy to .env and fill the remote OCR/LLM endpoints. DocLayout runs locally;
# OCR + LLM are reached remotely (e.g. Colab/RunPod for OCR, OpenRouter/company
# GPU for LLM). SAP is not reachable locally -> the spec lookup chain resolves
# via the LLM-extracted spec name against the locally indexed spec store.
# ==========================================================================

ENVIRONMENT=local
LOG_LEVEL=INFO
STORAGE_PATH=data

# Local: ONLY DocLayout
DOCLAYOUT_PROVIDER=paddlex_doclayout
LAYOUT_MODEL_DIR=models/PP-DocLayoutV3_safetensors
LAYOUT_DEVICE=cpu

# Remote OCR (fill with your endpoint + token)
OCR_PROVIDER=paddleocr_vl
OCR_REMOTE_BASE_URL=https://REPLACE_OCR_HOST
OCR_RECOGNIZE_PATH=/v1/chat/completions
OCR_REMOTE_BEARER_TOKEN=REPLACE_ME
OCR_MODEL_NAME=paddleocr-vl-16
OCR_BATCH_SIZE=4
OCR_MAX_WORKERS=4
OCR_TIMEOUT=600
# Lower per-call generation so a single big region finishes under proxy timeouts:
OCR_LOCAL_MAX_NEW_TOKENS=512

# Remote LLM (OpenRouter free Qwen, or company GPU)
LLM_PROVIDER=openai_compatible
LLM_REMOTE_BASE_URL=https://openrouter.ai/api/v1
LLM_REMOTE_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
LLM_REMOTE_BEARER_TOKEN=REPLACE_ME

# Spec: local indexed store; SAP not configured -> chain uses extracted spec name
ACTIVE_SAP_PROVIDER=local
SPEC_NETWORK_PATH=data/spec_store/mock_specs
ACTIVE_SPEC_STORE=sqlite
SPEC_STORE_DB_PATH=data/spec_store/spec_store.db

# Performance
PAGE_PARALLELISM=true
PAGE_RENDER_MAX_WORKERS=2
PDF_RENDER_DPI=150
