# ==========================================================================
# QC Inspector — COMPANY / PRODUCTION env template.
# Copy to .env and fill ONLY URLs, tokens, certificate paths, network paths.
# No code change is needed to deploy. NEVER commit a real .env. No secrets here.
# Config fails fast at startup if required values are missing (ENVIRONMENT=production).
# ==========================================================================

ENVIRONMENT=production
BACKEND_BASE_URL=https://qc-inspector.internal
FRONTEND_BASE_URL=https://qc-inspector.internal
LOG_LEVEL=INFO

# ---- Storage & scale ----
OUTPUT_ROOT=/var/lib/qc-inspector/output        # vendor job artifacts
SPEC_NETWORK_PATH=//fileserver/specs            # UNC/network path of spec PDFs

# Spec store: SQLite is fine for small/medium volume; Postgres for high volume /
# multiple replicas.
ACTIVE_SPEC_STORE=sqlite                        # sqlite | postgres
SPEC_STORE_DB_PATH=/var/lib/qc-inspector/spec_store.db
# ACTIVE_SPEC_STORE=postgres
# SPEC_INDEX_DB_URL=postgresql+psycopg://user:pass@db:5432/qc

# Artifact store: local FS (single server) or S3/MinIO (multi-replica / durable).
ACTIVE_OBJECT_STORE=local                       # local | s3
# ACTIVE_OBJECT_STORE=s3
# S3_BUCKET=qc-inspector-artifacts
# S3_ENDPOINT_URL=https://minio.internal        # leave empty for real AWS S3
#   (AWS creds via standard env: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)

# ---- Providers: DocLayout LOCAL, OCR + LLM REMOTE on the GPU server ----
DOCLAYOUT_PROVIDER=paddlex_doclayout
LAYOUT_MODEL_DIR=/opt/models/PP-DocLayoutV3_safetensors
LAYOUT_DEVICE=cpu

OCR_PROVIDER=paddleocr_vl                        # remote GPU OCR service
OCR_REMOTE_BASE_URL=https://ocr.gpu.internal
OCR_RECOGNIZE_PATH=/v1/chat/completions
OCR_REMOTE_BEARER_TOKEN=REPLACE_ME
OCR_MODEL_NAME=paddleocr-vl-16
OCR_REMOTE_CA_BUNDLE=/etc/ssl/company-ca.pem    # internal CA bundle
OCR_REMOTE_VERIFY_TLS=true

LLM_PROVIDER=openai_compatible                   # company GPU LLM (Qwen-class)
LLM_REMOTE_BASE_URL=https://llm.gpu.internal/v1
LLM_REMOTE_MODEL=qwen2.5-72b-instruct
LLM_REMOTE_BEARER_TOKEN=REPLACE_ME
LLM_REMOTE_CA_BUNDLE=/etc/ssl/company-ca.pem
LLM_REMOTE_VERIFY_TLS=true

# Shared default CA/verify (used if a per-service one is unset)
AI_SERVICE_CA_BUNDLE=/etc/ssl/company-ca.pem
AI_SERVICE_VERIFY_TLS=true

# ---- SAP / spec lookup service ----
ACTIVE_SAP_PROVIDER=real
SAP_SPEC_SERVICE_BASE_URL=https://sap.internal/erp-mm/part-spec
SAP_SPEC_SERVICE_ENDPOINT=/read-text
SAP_SPEC_SERVICE_BEARER_TOKEN=REPLACE_ME        # or SAP_API_USER/SAP_API_PASSWORD for Basic
SAP_SPEC_SERVICE_TIMEOUT_SECONDS=150
# SAP spec endpoint does not require certificate verification (default false).
# To enable it, set a CA bundle and SAP_SPEC_SERVICE_VERIFY_TLS=true.
# SAP_SPEC_SERVICE_CA_BUNDLE=/etc/ssl/company-ca.pem
SAP_SPEC_SERVICE_VERIFY_TLS=false

# ---- Performance / concurrency (values tuned for an H200 GPU endpoint) ----
PAGE_PARALLELISM=true
PAGE_RENDER_MAX_WORKERS=6                        # pages processed concurrently (single server: 2)
OCR_MAX_WORKERS=12                               # remote OCR concurrency per page (single server: 4)
OCR_BATCH_SIZE=12                                # keep aligned with OCR_MAX_WORKERS
DOCLAYOUT_MAX_WORKERS=1                          # paddlex is thread-affine — MUST stay 1
PDF_RENDER_DPI=150                               # raise to 200–220 for small-print docs
# Optional perf: skip OCR for these DocLayout region types (empty = OCR all,
# miss nothing). Only set after confirming such regions carry no text.
# OCR_SKIP_REGION_TYPES=figure,image
SPEC_INDEX_BATCH_SIZE=16

# ---- Timeouts (seconds) ----
REQUEST_TIMEOUT=120                              # general HTTP
OCR_TIMEOUT=1800                                 # OCR service (high for large/dense pages)
SEGMENTATION_TIMEOUT_SECONDS=600                 # LLM segmentation
COMPARISON_TIMEOUT_SECONDS=600                   # LLM comparison (raise for long docs)
SAP_SPEC_SERVICE_TIMEOUT_SECONDS=150             # SAP request

# ---- Resilience ----
RETRY_COUNT=3                                    # retry transient errors
CIRCUIT_BREAKER_FAIL_MAX=5                       # consecutive failures per host -> open
CIRCUIT_BREAKER_RESET_SECONDS=30                 # half-open trial after this

# ---- Scheduled spec indexing (cron) ----
SPEC_INDEX_SCHEDULE=0 2 * * *                    # nightly; empty disables in-app scheduler
SPEC_INDEX_MODE=incremental
SPEC_FORCE_OCR=true                              # OCR every spec PDF (digital or scanned)

# ---- Job queue ----
ACTIVE_JOB_QUEUE=inprocess                        # inprocess | celery
JOB_WORKERS=4
JOB_MAX_ATTEMPTS=3
